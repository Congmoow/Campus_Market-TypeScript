# ==========================================
# Campus Market Frontend - Environment Variables
# ==========================================

# ==========================================
# API Configuration
# ==========================================
# Backend API URL (used in production)
# In development, Vite proxy is used instead
VITE_API_URL=http://localhost:3000/api

# ==========================================
# Application
# ==========================================
# Application name
VITE_APP_NAME="Campus Market"

# Application version
VITE_APP_VERSION=1.0.0

# ==========================================
# Features (Optional)
# ==========================================
# Enable/disable features
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_CHAT=true
# VITE_ENABLE_NOTIFICATIONS=true

# ==========================================
# Third-party Services (Optional)
# ==========================================
# Google Analytics
# VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X

# Sentry (Error tracking)
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ==========================================
# Notes
# ==========================================
# 1. Copy this file to .env and fill in your actual values
# 2. NEVER commit .env file to version control
# 3. All Vite env variables must start with VITE_
# 4. Changes to .env require restarting the dev server
