generator client {
  provider = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           BigInt   @id @default(autoincrement())
  studentId    String   @unique @map("student_id") @db.VarChar(50)
  phone        String?  @unique @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(200)
  role         String   @default("USER") @db.VarChar(20)
  enabled      Boolean  @default(true)
  createdAt    DateTime @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @map("updated_at") @db.Timestamp(6)

  @@map("user")
}

model UserProfile {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @unique(map: "uk_user_profile_user_id") @map("user_id")
  avatarUrl String?  @map("avatar_url")
  major     String?  @db.VarChar(100)
  grade     String?  @db.VarChar(100)
  campus    String?  @db.VarChar(100)
  credit    Int      @default(700)
  bio       String?  @db.VarChar(500)
  createdAt DateTime @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @map("updated_at") @db.Timestamp(6)
  studentId String?  @map("student_id") @db.VarChar(50)
  name      String?  @db.VarChar(50)

  @@index([studentId], map: "idx_user_profile_student_id")
  @@map("user_profile")
}

model Product {
  id            BigInt         @id @default(autoincrement())
  sellerId      BigInt         @map("seller_id")
  title         String         @db.VarChar(200)
  description   String
  categoryId    BigInt?        @map("category_id")
  price         Decimal        @db.Decimal(10, 2)
  originalPrice Decimal?       @map("original_price") @db.Decimal(10, 2)
  status        String         @default("ON_SALE") @db.VarChar(20)
  location      String?        @db.VarChar(100)
  viewCount     BigInt         @default(0) @map("view_count")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  images        ProductImage[]

  @@index([categoryId, createdAt(sort: Desc)], map: "idx_product_category_id_created_at")
  @@index([sellerId, createdAt(sort: Desc)], map: "idx_product_seller_id_created_at")
  @@index([status, createdAt(sort: Desc)], map: "idx_product_status_created_at")
  @@index([status, price], map: "idx_product_status_price")
  @@index([status, viewCount(sort: Desc)], map: "idx_product_status_view_count")
  @@map("product")
}

model ProductImage {
  id         BigInt  @id @default(autoincrement())
  productId  BigInt  @map("product_id")
  url        String  @db.VarChar(255)
  sort_order Int     @default(0)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([productId, sort_order, id], map: "idx_product_image_product_id_sort_order")
  @@map("product_image")
}

model Category {
  id   BigInt @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  @@map("category")
}

model Order {
  id             BigInt    @id @default(autoincrement())
  buyerId        BigInt    @map("buyer_id")
  sellerId       BigInt    @map("seller_id")
  productId      BigInt    @map("product_id")
  status         String    @default("PENDING") @db.VarChar(20)
  price_snapshot Decimal   @db.Decimal(10, 2)
  meet_location  String?   @db.VarChar(100)
  meet_time      DateTime? @db.Timestamp(6)
  createdAt      DateTime  @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  order_no       String    @unique @db.VarChar(50)

  @@index([buyerId, createdAt(sort: Desc), id(sort: Desc)], map: "idx_orders_buyer_id_created_at")
  @@index([buyerId, status, createdAt(sort: Desc), id(sort: Desc)], map: "idx_orders_buyer_id_status_created_at")
  @@index([sellerId, createdAt(sort: Desc), id(sort: Desc)], map: "idx_orders_seller_id_created_at")
  @@index([sellerId, status, createdAt(sort: Desc), id(sort: Desc)], map: "idx_orders_seller_id_status_created_at")
  @@map("orders")
}

model ChatSession {
  id        BigInt        @id @default(autoincrement())
  productId BigInt        @map("product_id")
  buyerId   BigInt        @map("buyer_id")
  sellerId  BigInt        @map("seller_id")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  messages  ChatMessage[]

  @@unique([productId, buyerId, sellerId])
  @@index([buyerId], map: "idx_chat_session_buyer_id")
  @@index([sellerId], map: "idx_chat_session_seller_id")
  @@index([productId], map: "idx_chat_session_product_id")
  @@map("chat_session")
}

model ChatMessage {
  id         BigInt      @id @default(autoincrement())
  sessionId  BigInt      @map("session_id")
  senderId   BigInt      @map("sender_id")
  content    String
  type       String      @default("TEXT") @db.VarChar(20)
  isRecalled Boolean     @default(false) @map("is_recalled")
  isRead     Boolean     @default(false) @map("is_read")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_chat_message_session")

  @@index([sessionId], map: "idx_chat_message_session_id")
  @@index([senderId], map: "idx_chat_message_sender_id")
  @@map("chat_message")
}

model Favorite {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  productId BigInt   @map("product_id")
  createdAt DateTime @map("created_at") @db.Timestamp(6)

  @@unique([userId, productId], map: "uk_favorite_user_product")
  @@index([userId], map: "idx_favorite_user_id")
  @@index([productId], map: "idx_favorite_product_id")
  @@map("favorite")
}

model RefreshSession {
  id                 BigInt    @id @default(autoincrement())
  userId             BigInt    @map("user_id")
  tokenHash          String    @unique @map("token_hash") @db.VarChar(128)
  userAgent          String?   @map("user_agent") @db.VarChar(500)
  ipAddress          String?   @map("ip_address") @db.VarChar(64)
  expiresAt          DateTime  @map("expires_at") @db.Timestamp(6)
  revokedAt          DateTime? @map("revoked_at") @db.Timestamp(6)
  replacedByTokenHash String?  @map("replaced_by_token_hash") @db.VarChar(128)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([userId], map: "idx_refresh_session_user_id")
  @@index([expiresAt], map: "idx_refresh_session_expires_at")
  @@map("refresh_session")
}
