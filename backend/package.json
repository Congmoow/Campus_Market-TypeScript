{
  "name": "campus-market-backend",
  "version": "1.0.0",
  "description": "Campus Market Backend - Node.js + Express + TypeScript + Prisma",
  "main": "dist/server.js",
  "scripts": {
    "prepare:artifacts": "npm --workspace @campus-market/shared run build && npm run prisma:generate",
    "predev": "npm run prepare:artifacts",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "pretypecheck": "npm run prepare:artifacts",
    "prebuild": "npm run prepare:artifacts",
    "build": "tsc",
    "lint": "eslint \"src/**/*.ts\"",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "test:prepare-db": "npm run prisma:push -- --skip-generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "pretest": "npm run prepare:artifacts",
    "test": "jest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "campus",
    "market",
    "typescript",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^6.16.0",
    "@prisma/client": "^6.16.0",
    "@campus-market/shared": "file:../packages/shared",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "prisma": "^6.16.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
