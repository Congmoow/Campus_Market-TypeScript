# ==========================================
# Campus Market Docker Environment Variables
# Copy this file to the repository root as .env before running docker compose
# Production deployments must replace all example secrets and database passwords
# ==========================================

# PostgreSQL
POSTGRES_DB=campus_market
POSTGRES_USER=campus_market
POSTGRES_PASSWORD=change-this-db-password-in-production

# Backend
DATABASE_URL=postgresql://campus_market:change-this-db-password-in-production@postgres:5432/campus_market?schema=public
JWT_SECRET=replace-with-a-long-random-jwt-secret-in-production
FRONTEND_URL=http://localhost,http://127.0.0.1
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
PRISMA_ALLOW_DB_PUSH_FALLBACK=true

# Frontend
# The default Docker deployment uses nginx to reverse proxy /api to backend,
# so /api is the recommended value. Override only when you intentionally want
# the built frontend to call a different API base URL.
VITE_API_URL=/api

# Optional
UPLOAD_DIR=uploads
