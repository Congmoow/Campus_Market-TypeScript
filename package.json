{
  "name": "campus-market",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "packages/shared"
  ],
  "scripts": {
    "prepare:backend-artifacts": "npm run build:shared && npm --workspace campus-market-backend run prisma:generate",
    "dev": "concurrently -n \"backend,frontend\" -c \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "lint": "npm run lint:backend && npm run lint:frontend && npm run lint:shared",
    "lint:backend": "npm --workspace campus-market-backend run lint",
    "lint:frontend": "npm --workspace campus-market-frontend run lint",
    "lint:shared": "npm --workspace @campus-market/shared run lint",
    "typecheck": "npm run typecheck:shared && npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "npm --workspace campus-market-backend run typecheck",
    "typecheck:frontend": "npm --workspace campus-market-frontend run typecheck",
    "typecheck:shared": "npm --workspace @campus-market/shared run typecheck",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:shared": "npm --workspace @campus-market/shared run build",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "test": "npm run test:backend && npm run test:frontend",
    "docker:acceptance": "node scripts/docker-acceptance.mjs",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "npm run prepare:backend-artifacts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  }
}
